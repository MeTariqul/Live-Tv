# =============================================================================
# SECURITY: Generate bcrypt hash for admin password
# Run: python -c "import bcrypt; print(bcrypt.hashpw('YourPassword'.encode(), bcrypt.gensalt()).decode())"
# Then paste the output hash here.
# =============================================================================
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$12$REPLACE_WITH_ACTUAL_BCRYPT_HASH

# =============================================================================
# JWT (mandatory, min 64 chars)
# =============================================================================
JWT_SECRET=change-me-to-a-64-char-random-string

# =============================================================================
# Mux credentials (get from https://dashboard.mux.com/settings/access-tokens)
# =============================================================================
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret
MUX_PLAYBACK_POLICY=public

# =============================================================================
# Frontend origin for CORS
# =============================================================================
FRONTEND_ORIGIN=http://localhost:3000

# =============================================================================
# Vercel KV (Redis) credentials
# Get from Vercel dashboard after adding KV integration
# =============================================================================
KV_REST_API_URL=https://your-kv-rest-api-url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
