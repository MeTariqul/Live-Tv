# Environment Variables
# Copy this to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL_PRODUCTION=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-a-64-char-random-secret

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password

# Streaming Platform
NEXT_PUBLIC_STREAM_PLATFORM=youtube
NEXT_PUBLIC_STREAM_EMBED_ID=your-youtube-live-video-id
NEXT_PUBLIC_TWITCH_CHANNEL=your-twitch-channel

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site
NEXT_PUBLIC_SITE_NAME=StreamHub
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
